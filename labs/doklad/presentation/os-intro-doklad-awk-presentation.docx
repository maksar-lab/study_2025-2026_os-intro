\section{Содержание
исследования}\label{ux441ux43eux434ux435ux440ux436ux430ux43dux438ux435-ux438ux441ux441ux43bux435ux434ux43eux432ux430ux43dux438ux44f}

\begin{frame}[fragile]{Что такое awk?}
\protect\phantomsection\label{ux447ux442ux43e-ux442ux430ux43aux43eux435-awk}
\begin{itemize}
\tightlist
\item
  Утилита командной строки для обработки текстовых файлов
\item
  Язык программирования для работы со структурированными данными
\item
  Синтаксис:
  \texttt{awk\ \textquotesingle{}условие\ \{действие\}\textquotesingle{}\ файл}
\end{itemize}
\end{frame}

\begin{frame}[fragile]{Базовый синтаксис}
\protect\phantomsection\label{ux431ux430ux437ux43eux432ux44bux439-ux441ux438ux43dux442ux430ux43aux441ux438ux441}
\begin{itemize}
\tightlist
\item
  Строки автоматически разбиваются на поля
\item
  \texttt{\$1}, \texttt{\$2}, \ldots{} --- доступ к полям
\item
  \texttt{\$0} --- вся строка целиком
\item
  \texttt{NR} --- номер строки
\item
  \texttt{NF} --- количество полей
\end{itemize}
\end{frame}

